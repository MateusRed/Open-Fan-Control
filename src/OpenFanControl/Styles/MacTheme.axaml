<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <!-- LIGHT -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WindowBackground" Color="#F2F2F7" />
                    <SolidColorBrush x:Key="SidebarBackground" Color="#E9E9EF" />
                    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CardBorder" Color="#E2E2E7" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#1D1D1F" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#8A8A8E" />
                    <SolidColorBrush x:Key="SegmentGroup" Color="#E4E4EA" />
                    <SolidColorBrush x:Key="SegmentSelected" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="TitleBar" Color="#EDEDF2" />
                    <SolidColorBrush x:Key="Divider" Color="#E2E2E7" />
                </ResourceDictionary>

                <!-- DARK -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E20" />
                    <SolidColorBrush x:Key="SidebarBackground" Color="#252528" />
                    <SolidColorBrush x:Key="CardBackground" Color="#2C2C2E" />
                    <SolidColorBrush x:Key="CardBorder" Color="#3A3A3C" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F7" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#98989D" />
                    <SolidColorBrush x:Key="SegmentGroup" Color="#3A3A3C" />
                    <SolidColorBrush x:Key="SegmentSelected" Color="#636366" />
                    <SolidColorBrush x:Key="TitleBar" Color="#252528" />
                    <SolidColorBrush x:Key="Divider" Color="#3A3A3C" />
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- Typography -->
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    <Style Selector="TextBlock.section">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="Margin" Value="4,0,0,8" />
    </Style>
    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
    </Style>
    <Style Selector="TextBlock.value">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Cards -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource CardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BoxShadow" Value="0 1 3 0 #14000000" />
    </Style>

    <!-- Segmented control -->
    <Style Selector="Border.segmentGroup">
        <Setter Property="Background" Value="{DynamicResource SegmentGroup}" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <Style Selector="RadioButton.segment">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="seg" Background="Transparent" CornerRadius="7" Padding="16,6">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RadioButton.segment:checked /template/ Border#seg">
        <Setter Property="Background" Value="{DynamicResource SegmentSelected}" />
        <Setter Property="BoxShadow" Value="0 1 2 0 #22000000" />
    </Style>
    <Style Selector="RadioButton.segment:checked">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Traffic-light window buttons -->
    <Style Selector="Button.traffic">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" CornerRadius="6" />
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.traffic.close">
        <Setter Property="Background" Value="#FF5F57" />
    </Style>
    <Style Selector="Button.traffic.min">
        <Setter Property="Background" Value="#FEBC2E" />
    </Style>
    <Style Selector="Button.traffic.zoom">
        <Setter Property="Background" Value="#28C840" />
    </Style>
    <Style Selector="Button.traffic:pointerover">
        <Setter Property="Opacity" Value="0.8" />
    </Style>

    <!-- Slider accent -->
    <Style Selector="Slider">
        <Setter Property="MinHeight" Value="24" />
    </Style>

</Styles>
